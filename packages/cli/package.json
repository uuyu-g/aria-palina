{
  "name": "@aria-palina/cli",
  "version": "0.0.1",
  "description": "aria-palina CLI + TUI。Playwright 経由で AOM を取得し、デフォルトは NVDA 風テキストを stdout に出力 (ワンショット)、--tui フラグで Ink ベースの対話モードに切り替わる。",
  "bin": {
    "palina": "./dist/bin.mjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./tui": {
      "types": "./dist/tui/index.d.mts",
      "import": "./dist/tui/index.mjs"
    }
  },
  "scripts": {
    "build": "vp pack --dts --clean src/index.ts src/bin.ts src/tui/index.ts"
  },
  "dependencies": {
    "@aria-palina/core": "workspace:*",
    "ink": "^5.2.1",
    "playwright-core": "~1.56.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0"
  }
}
